{
  "lastChangelogVersion": "0.74.1",
  "packages": [
    "npm:pi-btw",
    "npm:pi-subagents",
    "npm:@juicesharp/rpiv-ask-user-question",
    "npm:@plannotator/pi-extension",
    "npm:pi-workspace-history"
  ],
  "defaultProvider": "oc",
  "defaultModel": "deepseek-v4-flash-free",
  "defaultThinkingLevel": "high",
  "theme": "catppuccin-mocha",
  "vstack": {
    "extensionManager": {
      "disabledItems": [],
      "config": {
        "@vanillagreen/pi-tool-renderer": {
          "batchMaxCalls": 20,
          "renderMutationTools": true,
          "workingIndicator": "pulse",
          "pendingStatusAnimation": true,
          "toolChrome": "off",
          "styledCodeBlocks": false
        },
        "pi-qol": {
          "permissionGate.enabled": true,
          "sessionAutoRename.model": "opencode/minimax-m2.5-free",
          "compaction.model": "opencode/minimax-m2.5-free",
          "compaction.customEnabled": false,
          "compaction.idleEnabled": false
        }
      }
    }
  },
  "hideThinkingBlock": true,
  "workspaceHistory": {
    "enabled": false
  }
}